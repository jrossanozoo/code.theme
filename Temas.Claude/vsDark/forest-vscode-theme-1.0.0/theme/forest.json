        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#C2FFC9"
      }
    },
    {
      "name": "String Literals",
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#C2E1FF"
      }
    }

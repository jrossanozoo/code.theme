{
  "name": "spring (GitHub Dark)",
  "type": "dark",
  "include": "./../../_base/__github-dark.json",
  "colors": {
    "activityBar.background": "#630059",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.border": "#400036",
    "activityBar.activeBorder": "#AC84A8",
    "activityBarBadge.background": "#AC84A8",
    "activityBarBadge.foreground": "#000000",
    "titleBar.activeBackground": "#630059",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#4F0045",
    "titleBar.inactiveForeground": "#A0A0A0",
    "titleBar.border": "#400036",
    "menubar.selectionBackground": "#7C1972",
    "menubar.selectionForeground": "#FFFFFF",
    "menu.background": "#630059",
    "menu.foreground": "#FFFFFF",
    "menu.selectionBackground": "#7C1972",
    "menu.selectionForeground": "#FFFFFF",
    "menu.border": "#4F0045",
    "statusBar.background": "#7C1972",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#4F0045",
    "statusBar.noFolderBackground": "#630059",
    "statusBarItem.hoverBackground": "#8B2881",
    "tab.border": "#4F0045",
    "tab.activeBorder": "#AC84A8",
    "tab.unfocusedActiveBorder": "#7C1972",
    "editorGroup.border": "#4F0045",
    "panel.border": "#4F0045",
    "focusBorder": "#AC84A8",
    "input.border": "#4F0045",
    "button.background": "#7C1972",
    "button.hoverBackground": "#8B2881",
    "diffEditor.removedLineBackground": "#DFC2FF40",
    "diffEditor.removedTextBackground": "#DFC2FF80",
    "diffEditor.insertedLineBackground": "#C2FAFF40",
    "diffEditor.insertedTextBackground": "#C2FAFF80"
  },
  "tokenColors": [
    {
      "name": "Language Syntax / Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#F8C2FF"
      }
    },
    {
      "name": "String Literals",
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#C5FFC2"
      }
    }
  ]
}

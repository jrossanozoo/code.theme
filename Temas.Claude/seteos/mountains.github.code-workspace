{
  "folders": [
    {
      "path": ".."
    }
  ],
  "settings": {
    "workbench.colorTheme": "mountains (GitHub Dark)",
    "workbench.colorCustomizations": {
      "activityBar.background": "#230052",
      "activityBar.foreground": "#FFFFFF",
      "activityBar.border": "#00002F",
      "activityBar.activeBorder": "#9284A5",
      "activityBarBadge.background": "#9284A5",
      "activityBarBadge.foreground": "#000000",
      "titleBar.activeBackground": "#230052",

{
  "$schema": "vscode://schemas/color-theme",
  "name": "Summer GitHub Dark",
  "include": "../../_base/github-dark-default.json",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#72723A",
    "activityBar.background": "#323201",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.border": "#242401",
    "activityBar.activeBorder": "#72723A",
    "activityBarBadge.background": "#4A4A02",
    "activityBarBadge.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#323201",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#242401",
    "titleBar.inactiveForeground": "#8F8F62",
    "titleBar.border": "#242401",
    "statusBar.background": "#4A4A02",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#72723A",
    "statusBar.noFolderBackground": "#323201",
    "statusBar.noFolderForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#72723A33",
    "menubar.selectionBackground": "#4A4A0233",
    "menubar.selectionForeground": "#FFFFFF",
    "menu.selectionBackground": "#4A4A0233",
    "menu.selectionForeground": "#FFFFFF",
    "menu.border": "#242401",
    "commandCenter.activeBackground": "#4A4A0230",
    "commandCenter.activeForeground": "#FFFFFF",
    "notificationCenterHeader.background": "#323201",
    "notificationCenterHeader.foreground": "#FFFFFF",
    "notifications.background": "#1A1A0F",
    "notifications.foreground": "#FFFFFF",
    "notifications.border": "#4A4A02",
    "panel.border": "#242401",
    "sideBar.border": "#242401",
    "editorGroup.border": "#242401",
    "pickerGroup.border": "#4A4A02",
    "inputOption.activeBorder": "#72723A",
    "badge.background": "#4A4A02",
    "badge.foreground": "#FFFFFF",
    "progressBar.background": "#72723A",
    "toolbar.hoverBackground": "#4A4A0222",
    "toolbar.activeBackground": "#4A4A0233",
    "diffEditor.removedLineBackground": "#F7C2FF1F",
    "diffEditor.removedTextBackground": "#F7C2FF44",
    "diffEditorGutter.removedLineBackground": "#F7C2FF66",
    "diffEditor.insertedLineBackground": "#C2FFC91F",
    "diffEditor.insertedTextBackground": "#C2FFC944",
    "diffEditorGutter.insertedLineBackground": "#C2FFC966"
  },
  "tokenColors": [
    {
      "name": "Language syntax",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.word",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFFAC2"
      }
    },
    {
      "name": "Literal values",
      "scope": [
        "string",
        "string.quoted",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape"
      ],
      "settings": {
        "foreground": "#C2E6FF"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#FFFAC2",
    "string": "#C2E6FF",
    "number": "#C2E6FF"
  }
}

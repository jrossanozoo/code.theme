{
    "folders": [
        {
            "path": "."
        }
    ],
    "settings": {
        "workbench.colorTheme": "spring (GitHub Dark)",
        "workbench.colorCustomizations": {
            "activityBar.background": "#630059",
            "titleBar.activeBackground": "#630059",
            "statusBar.background": "#630059",
            "diffEditor.removedTextBackground": "#DFC2FF40",
            "diffEditor.insertedTextBackground": "#C2FAFF40",
            "textMateRules": [
                {
                    "scope": [
                        "keyword",
                        "storage"
                    ],
                    "settings": {
                        "foreground": "#F8C2FF"

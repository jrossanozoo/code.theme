                {
                    "scope": [
                        "string",
                        "constant.numeric"
                    ],
                    "settings": {
                        "foreground": "#C5FFC2"
                    }
                }
            ]
        },
        "zoo-tool-kit.showExtensionRecommendations": false
    }
